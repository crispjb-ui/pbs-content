{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/session_sync.sh" },
          { "type": "command", "command": "bash .claude/hooks/session_digest_check.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/brand_lint_check.sh" }
        ]
      }
    ]
  }
}
